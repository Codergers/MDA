{
    "task": [
        {
            "name": "SmallEvent",
            "label": "$task.SmallEvent.label",
            "entry": "SmallEventMain",
            "description": "$task.SmallEvent.description",
            "option": [
                "SmallEventTheme",
                "SmallEventChallenge",
                "SmallEventStory",
                "SmallEventMission"
            ],
            "group": [
                "periodic"
            ]
        }
    ],
    "option": {
        "SmallEventTheme": {
            "type": "select",
            "default_case": "BitterSpice",
            "label": "$option.SmallEventTheme.label",
            "cases": [
                {
                    "name": "BitterSpice",
                    "label": "$option.SmallEventTheme.BitterSpice",
                    "pipeline_override": {
                        "SmallEventEnterMainPage": {
                            "recognition": {
                                "param": {
                                    "template": [
                                        "SmallEvent/BitterSpice/BitterSpiceLogo.png"
                                    ]
                                }
                            }
                        },
                        "SmallEventClickStage": {
                            "recognition": {
                                "param": {
                                    "template": [
                                        "SmallEvent/BitterSpice/BitterSpiceStageNormal.png",
                                        "SmallEvent/BitterSpice/BitterSpiceStageNormalSP.png",
                                        "SmallEvent/BitterSpice/BitterSpiceStageHard.png"
                                    ]
                                }
                            }
                        },
                        "SmallEventClickStageRepeatable": {
                            "recognition": {
                                "param": {
                                    "template": [
                                        "SmallEvent/BitterSpice/BitterSpiceStageNormalRepeatable.png",
                                        "SmallEvent/BitterSpice/BitterSpiceStageNormalRepeatableSP.png",
                                        "SmallEvent/BitterSpice/BitterSpiceStageHardRepeatable.png"
                                    ]
                                }
                            }
                        }
                    }
                },
                {
                    "name": "BSideIdol",
                    "label": "$option.SmallEventTheme.BSideIdol",
                    "pipeline_override": {
                        "SmallEventEnterMainPage": {
                            "recognition": {
                                "param": {
                                    "template": [
                                        "SmallEvent/B-SideIdol/B-SideIdolLogo.png"
                                    ]
                                }
                            }
                        },
                        "SmallEventClickStage": {
                            "recognition": {
                                "param": {
                                    "template": [
                                        "SmallEvent/B-SideIdol/B-SideIdolStageNormal.png",
                                        "SmallEvent/B-SideIdol/B-SideIdolStageHard.png"
                                    ]
                                }
                            }
                        },
                        "SmallEventClickStageRepeatable": {
                            "recognition": {
                                "param": {
                                    "template": [
                                        "SmallEvent/B-SideIdol/B-SideIdolStageNormalRepeatable.png",
                                        "SmallEvent/B-SideIdol/B-SideIdolStageHardRepeatable.png"
                                    ]
                                }
                            }
                        }
                    }
                },
                {
                    "name": "Other",
                    "label": "$option.SmallEventTheme.Other"
                }
            ]
        },
        "SmallEventChallenge": {
            "type": "switch",
            "default_case": "Yes",
            "label": "$option.SmallEventContent.SmallEventChallenge",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "SmallEventEnterChallenge": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "SmallEventEnterChallenge": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "SmallEventStory": {
            "type": "switch",
            "default_case": "Yes",
            "label": "$option.SmallEventContent.SmallEventStory",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "SmallEventEnterStory": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "SmallEventEnterStory": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "SmallEventMission": {
            "type": "switch",
            "default_case": "Yes",
            "label": "$option.SmallEventContent.SmallEventMission",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "SmallEventEnterMission": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "SmallEventEnterMission": {
                            "enabled": false
                        }
                    }
                }
            ]
        }
    }
}
